{
  "name": "node",
  "version": "2.2.0",
  "main": "server.js",
  "scripts": {
    "build": "tsc && npm run copy-views",
    "copy-views": "copyfiles -u 0 'views/**/*' 'module/**/*' dist",
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "changelog": "./generate-changelog.sh",
    "sync-version": "./sync-version.sh",
    "bump-patch": "./bump-version.sh patch",
    "bump-minor": "./bump-version.sh minor",
    "bump-major": "./bump-version.sh major",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "body-parser": "^1.20.3",
    "chokidar": "^4.0.1",
    "crypto-js": "^4.1.1",
    "dotenv": "^16.5.0",
    "escape-string-regexp": "^5.0.0",
    "eslint-config-prettier": "^10.1.8",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-handlebars": "^6.0.6",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "js-yaml": "^4.1.0",
    "lodash": "^4.14.191",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.1",
    "papaparse": "^5.4.1",
    "puppeteer": "^23.9.0",
    "replace-in-file": "^6.3.5",
    "yaml": "^2.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/body-parser": "^1.19.6",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.21",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.14",
    "@types/nodemailer": "^7.0.4",
    "@types/papaparse": "^5.5.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1.3.4",
    "@vitest/ui": "^3.2.4",
    "copyfiles": "^2.4.1",
    "eslint": "^9.32.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-sonarjs": "^3.0.4",
    "eslint-plugin-sort-export-all": "^2.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.3.0",
    "husky": "^9.1.6",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "^20.19.3",
    "npm": "^10.8.2"
  }
}
